# NexCard E2E example env
# Copy to .env.e2e.local for local Cypress runs.
# The runner prefers .env.e2e.local over .env.local so you can keep test data isolated.

# App URLs / ports
PUBLIC_APP_URL="http://localhost:3000"
E2E_FRONTEND_PORT="3000"
E2E_BACKEND_PORT="4000"
E2E_WAIT_ON_TIMEOUT_MS="120000"

# Admin login used by Cypress custom command
CYPRESS_login_email="admin@nexcard.cl"
CYPRESS_login_password="replace-with-valid-admin-password"

# NFC bridge smoke seed
CYPRESS_nfc_token="replace-with-live-public-token"
CYPRESS_nfc_expected_slug="carlos-alvarez"

# Soft delete guard seed
CYPRESS_deleted_profile_slug="bot-carlos"

# Cards lifecycle seeds
CYPRESS_revoked_nfc_token="nxc-revoked-token"
CYPRESS_revoked_expected_status="revoked"
CYPRESS_revoked_card_code="NXC-REV-001"
CYPRESS_archived_nfc_token="nxc-archived-token"
CYPRESS_archived_expected_status="archived"
CYPRESS_archived_card_code="NXC-ARC-001"

# Admin profiles seeds
CYPRESS_active_profile_slug="carlos-alvarez"
CYPRESS_active_profile_full_name="Carlos Alvarez"
CYPRESS_active_profile_status="active"
CYPRESS_active_profile_versions="2"
CYPRESS_active_profile_last_event="snapshot"
CYPRESS_archived_profile_slug="bot-carlos"
CYPRESS_archived_profile_full_name="Bot Carlos"
CYPRESS_archived_profile_status="archived"
CYPRESS_archived_profile_versions="3"
CYPRESS_archived_profile_last_event="soft_delete"
