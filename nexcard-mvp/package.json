{
  "name": "nexcard-mvp",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.104.0",
    "autoprefixer": "^10.4.16",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^0.284.0",
    "postcss": "^8.5.20",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.3",
    "zustand": "^5.0.12"
  },
  "scripts": {
    "start": "vite --host 127.0.0.1 --port ${PORT:-3000}",
    "build": "vite build",
    "test": "node ./scripts/vitest-run.mjs",
    "test:unit": "node ./scripts/vitest-run.mjs",
    "lint": "eslint src/App.jsx src/services src/config server --ext js,jsx",
    "kpi:evaluate": "node ./scripts/run-executive-alert-evaluator.mjs manual",
    "kpi:evaluate:cron": "node ./scripts/run-executive-alert-evaluator.mjs cron",
    "ops:reconcile-orders": "node ./scripts/run-order-payment-reconciliation.mjs manual",
    "ops:reconcile-orders:dry": "node ./scripts/run-order-payment-reconciliation.mjs manual --dry-run",
    "ops:reconcile-orders:cron": "node ./scripts/run-order-payment-reconciliation.mjs cron",
    "ops:backfill-payments": "node ./scripts/run-payment-ledger-backfill.mjs manual",
    "ops:backfill-payments:dry": "node ./scripts/run-payment-ledger-backfill.mjs manual --dry-run",
    "check:fast": "npm run build",
    "check:smoke": "npm run build && npm run test:e2e:smoke",
    "check": "npm run build && npm run test:e2e:env-check && npm run test:e2e:smoke",
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "cypress:open": "cypress open",
    "test:e2e": "cypress run",
    "test:e2e:env-check": "node ./scripts/e2e-env-check.js local",
    "test:e2e:local": "./scripts/run-e2e-local.sh",
    "test:e2e:smoke": "./scripts/run-e2e-local.sh --spec cypress/e2e/smoke.cy.js",
    "test:e2e:nfc": "./scripts/run-e2e-local.sh --spec cypress/e2e/nfc-bridge.cy.js",
    "test:e2e:soft-delete": "./scripts/run-e2e-local.sh --spec cypress/e2e/profile-soft-delete-guard.cy.js",
    "test:e2e:nfc-invalid": "./scripts/run-e2e-local.sh --spec cypress/e2e/nfc-invalid-card-states.cy.js",
    "test:e2e:admin-cards": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-cards.cy.js",
    "test:e2e:admin-cards-guardrails": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-cards.cy.js",
    "test:e2e:cards-lifecycle": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-cards.cy.js --spec cypress/e2e/nfc-invalid-card-states.cy.js",
    "test:e2e:admin-profiles": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-profiles.cy.js",
    "test:e2e:admin-profiles-guardrails": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-profiles.cy.js",
    "test:e2e:profiles-e2e": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-profiles-e2e.cy.js",
    "test:e2e:profiles-full": "./scripts/run-e2e-local.sh --spec cypress/e2e/admin-profiles.cy.js --spec cypress/e2e/admin-profiles-e2e.cy.js --spec cypress/e2e/profile-soft-delete-guard.cy.js",
    "ops:prelaunch-audit": "node ./scripts/audit-prelaunch-readiness.mjs"
  },
  "devDependencies": {
    "@testing-library/cypress": "^10.0.3",
    "concurrently": "^9.1.2",
    "cypress": "^15.18.1",
    "wait-on": "^8.0.1",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "vitest": "^4.0.15",
    "jsdom": "^27.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "qs": "^6.15.3",
    "serialize-javascript": "^7.0.7",
    "underscore": "^1.13.8",
    "uuid": "^11.1.1"
  }
}
